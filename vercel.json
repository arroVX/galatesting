{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php"
        }
    ],
    "routes": [
        {
            "src": "/(css|js|images|fonts|favicon.ico|favicon.png|robots.txt)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
